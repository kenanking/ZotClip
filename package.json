{
  "name": "zotclip",
  "type": "module",
  "version": "0.2.6",
  "description": "Copy Zotero attachments to clipboard.",
  "config": {
    "addonName": "ZotClip",
    "addonID": "zotclip@cvrsg.dev",
    "addonRef": "zotclip",
    "addonInstance": "ZotClip",
    "prefsPrefix": "extensions.zotero.zotclip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenanking/ZotClip.git"
  },
  "author": "Yan Tang",
  "bugs": {
    "url": "https://github.com/kenanking/ZotClip/issues"
  },
  "homepage": "https://github.com/kenanking/ZotClip#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test --no-watch",
    "update-deps": "npm update --save",
    "test:unit": "tsx --test spec/unit/**/*.test.ts"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "5.1.2"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "eslint": "10.1.0",
    "mocha": "^11.7.5",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "0.8.5",
    "zotero-types": "4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
