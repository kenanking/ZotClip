pref-auto-tag-enabled = Enable AI auto-tagging
pref-strip-connector-tags = Strip Zotero Connector tags on new item import
pref-auto-tag-on-add = Auto-generate AI tags for new items (RSS feed entries are skipped)
pref-ai-provider = Service Provider:
pref-auto-tag-model = Model:
pref-auto-tag-endpoint = API Endpoint:
pref-ai-test-connection = Test connection
pref-auto-tag-key = API Key:
pref-api-key-storage-note = Keys are stored in plain text in your Zotero profile. The API URL above can point to a local or custom OpenAI-compatible endpoint.
pref-ai-prompt = Prompt:
pref-ai-prompt-reset = Restore Default
pref-ai-prompt-help = In the prompt field you can use {"{"}title{"}"}, {"{"}abstract{"}"}, and {"{"}language{"}"} as placeholders (each wrapped in curly braces). {"{"}language{"}"} is replaced with the Zotero interface language so tags match your UI language. The entire prompt is sent as one user message.
